<Window x:Class="mapa_slepa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mapa_slepa"
        mc:Ignorable="d"
        Title="MainWindow"
        WindowState="Maximized"
        WindowStyle="None">
    <Grid>

        <Image Name="MapImage"
           Source="/img/czechia.png"
           Stretch="Uniform"
           SizeChanged="MapImage_SizeChanged"
           MouseDown="MapImage_MouseDown"/>

        <Canvas Name="OverlayCanvas"/>
        <TextBlock x:Name="Turn" HorizontalAlignment="Left" Margin="12,12,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="64" Width="209" FontSize="36"/>
        <TextBlock x:Name="Question" HorizontalAlignment="Left" Margin="336,12,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="64" Width="400" FontSize="36"/>
        <TextBlock x:Name="Points" HorizontalAlignment="Left" Margin="769,118,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="64" Width="181" FontSize="36" RenderTransformOrigin="0.513,0.492"/>

    </Grid>
</Window>
